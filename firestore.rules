rules_version = '2';
// v2: add remove-follower rule
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validNotificationSettingsWrite() {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'pushEnabled',
          'activity',
          'postsFromFollowing',
          'live',
          'subscriptions',
          'recommended',
          'updatedAt',
        ])
        && d.pushEnabled is bool
        && d.activity is bool
        && d.postsFromFollowing is bool
        && d.live is bool
        && d.subscriptions is bool
        && d.recommended is bool
        && d.updatedAt is timestamp;
    }

    // Merge updates must not change follower count; [==] fails when the field is
    // missing on legacy docs or when numeric types differ slightly.
    function followersCountUnchanged() {
      return int(request.resource.data.get('followersCount', 0))
        == int(resource.data.get('followersCount', 0));
    }

    function validUserDoc(userId) {
      return request.resource.data.keys().hasOnly([
        'uid',
        'email',
        'displayName',
        'username',
        'bio',
        'dob',
        'profileImage',
        'interests',
        'onboardingCompleted',
        'createdAt',
        'following',
        'blockedUsers',
        'followersCount',
        'emailOtpVerified',
        'isVerified',
        'verificationStatus',
        'accountType',
        'publicPersona',
        'vipVerified',
        'phoneNumber',
        'normalizedPhone',
        'orgProfileCompleted',
        'organizationDetails',
        'parentConsentStatus',
        'parentConsentId',
        'parentUid',
        'parentInviteEmail',
        'parentInvitePhone',
        'parentConsentAt',
      ]) &&
      request.resource.data.uid == userId &&
      request.resource.data.email is string &&
      (!('displayName' in request.resource.data) ||
        request.resource.data.displayName is string) &&
      request.resource.data.username is string &&
      (!('bio' in request.resource.data) ||
        request.resource.data.bio is string) &&
      request.resource.data.dob is string &&
      request.resource.data.profileImage is string &&
      request.resource.data.interests is list &&
      request.resource.data.onboardingCompleted is bool &&
      request.resource.data.createdAt is timestamp &&
      request.resource.data.following is list &&
      request.resource.data.blockedUsers is list &&
      request.resource.data.followersCount is int &&
      (!('emailOtpVerified' in request.resource.data) ||
        request.resource.data.emailOtpVerified is bool) &&
      (!('isVerified' in request.resource.data) ||
        request.resource.data.isVerified is bool) &&
      (!('verificationStatus' in request.resource.data) ||
        request.resource.data.verificationStatus is string) &&
      (!('accountType' in request.resource.data) ||
        request.resource.data.accountType is string) &&
      (!('publicPersona' in request.resource.data) ||
        request.resource.data.publicPersona is string) &&
      (!('vipVerified' in request.resource.data) ||
        request.resource.data.vipVerified is bool) &&
      (!('phoneNumber' in request.resource.data) ||
        request.resource.data.phoneNumber is string) &&
      (!('normalizedPhone' in request.resource.data) ||
        request.resource.data.normalizedPhone is string) &&
      (!('orgProfileCompleted' in request.resource.data) ||
        request.resource.data.orgProfileCompleted is bool) &&
      (!('organizationDetails' in request.resource.data) ||
        request.resource.data.organizationDetails is map) &&
      (!('parentConsentStatus' in request.resource.data) ||
        request.resource.data.parentConsentStatus is string) &&
      (!('parentConsentId' in request.resource.data) ||
        request.resource.data.parentConsentId is string) &&
      (!('parentUid' in request.resource.data) ||
        request.resource.data.parentUid is string) &&
      (!('parentInviteEmail' in request.resource.data) ||
        request.resource.data.parentInviteEmail is string) &&
      (!('parentInvitePhone' in request.resource.data) ||
        request.resource.data.parentInvitePhone is string) &&
      (!('parentConsentAt' in request.resource.data) ||
        request.resource.data.parentConsentAt is timestamp);
    }

    function parentalConsentCreateValid() {
      let k = request.resource.data.keys();
      return k.hasAll([
            'minorUid',
            'minorUsername',
            'parentEmailLower',
            'parentPhoneNormalized',
            'status',
            'createdAt',
          ])
          && k.size() == 6
          && request.resource.data.minorUid == request.auth.uid
          && request.resource.data.minorUsername is string
          && request.resource.data.parentEmailLower is string
          && request.resource.data.parentPhoneNormalized is string
          && request.resource.data.status == 'pending'
          && request.resource.data.createdAt != null
          && (
            request.resource.data.parentEmailLower.size() > 0
            || request.resource.data.parentPhoneNormalized.size() > 0
          );
    }

    // Phone-only Firebase accounts often have no [request.auth.token.email]; match invite
    // to [users/{uid}.email] so parents can list and read [parental_consents] by email query.
    function parentUserDocEmailMatchesInviteLower() {
      return resource.data.parentEmailLower is string
        && resource.data.parentEmailLower.size() > 0
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && 'email' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email is string
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email.lower()
          == resource.data.parentEmailLower;
    }

    function parentalConsentReadAllowed() {
      return resource.data.minorUid == request.auth.uid
        || (
          resource.data.parentEmailLower is string
          && resource.data.parentEmailLower.size() > 0
          && request.auth.token.email != null
          && request.auth.token.email.lower() == resource.data.parentEmailLower
        )
        || parentUserDocEmailMatchesInviteLower()
        || (
          resource.data.parentPhoneNormalized is string
          && resource.data.parentPhoneNormalized.size() > 0
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.normalizedPhone
            == resource.data.parentPhoneNormalized
        );
    }

    function parentalConsentParentCanRespond() {
      return (
          resource.data.parentEmailLower is string
          && resource.data.parentEmailLower.size() > 0
          && request.auth.token.email != null
          && request.auth.token.email.lower() == resource.data.parentEmailLower
        )
        || parentUserDocEmailMatchesInviteLower()
        || (
          resource.data.parentPhoneNormalized is string
          && resource.data.parentPhoneNormalized.size() > 0
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.normalizedPhone
            == resource.data.parentPhoneNormalized
        );
    }

    function parentalContactFieldsUnchanged() {
      return request.resource.data.get('parentConsentStatus', 'not_required')
          == resource.data.get('parentConsentStatus', 'not_required')
        && request.resource.data.get('parentConsentId', '')
          == resource.data.get('parentConsentId', '')
        && request.resource.data.get('parentUid', '') == resource.data.get('parentUid', '')
        && request.resource.data.get('parentInviteEmail', '')
          == resource.data.get('parentInviteEmail', '')
        && request.resource.data.get('parentInvitePhone', '')
          == resource.data.get('parentInvitePhone', '')
        && (
          !('parentConsentAt' in request.resource.data)
            && !('parentConsentAt' in resource.data)
          || request.resource.data.parentConsentAt == resource.data.parentConsentAt
        );
    }

    function minorDobAndParentGateUpdate(userId) {
      return isOwner(userId)
        && emailOtpVerifiedUnchanged()
        && followersCountUnchanged()
        // Do not use [validUserDoc] here: merged docs may include legacy/extra keys
        // not in the allowlist; [diff] already restricts this write to DOB + gate fields.
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dob', 'parentConsentStatus'])
        && request.resource.data.dob is string
        && request.resource.data.parentConsentStatus in ['pending_contact', 'not_required'];
    }

    function minorParentInviteSubmit(userId) {
      let cid = request.resource.data.parentConsentId;
      return isOwner(userId)
        && emailOtpVerifiedUnchanged()
        && followersCountUnchanged()
        // Do not use [validUserDoc]: same allowlist issue as [minorDobAndParentGateUpdate].
        // [diff().affectedKeys().hasOnly] ensures no other profile fields change in this write.
        // Allow [pending_contact] (normal) or [pending] (retry / stale consent id / race).
        && (
          resource.data.parentConsentStatus == 'pending_contact'
          || resource.data.parentConsentStatus == 'pending'
        )
        && request.resource.data.parentConsentStatus == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'parentConsentStatus',
            'parentConsentId',
            'parentInviteEmail',
            'parentInvitePhone',
          ])
        && cid is string
        && cid.size() > 0
        && get(/databases/$(database)/documents/parental_consents/$(cid)).data.minorUid == userId
        && get(/databases/$(database)/documents/parental_consents/$(cid)).data.status == 'pending';
    }

    function minorParentalConsentSync(userId) {
      let cid = resource.data.parentConsentId;
      return isOwner(userId)
        && emailOtpVerifiedUnchanged()
        && followersCountUnchanged()
        && cid is string
        && cid.size() > 0
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['parentConsentStatus', 'parentUid', 'parentConsentAt'])
        && resource.data.parentConsentId == request.resource.data.parentConsentId
        && resource.data.parentConsentStatus == 'pending'
        && get(/databases/$(database)/documents/parental_consents/$(cid)).data.minorUid == userId
        && (
          (
            request.resource.data.parentConsentStatus == 'approved'
            && get(/databases/$(database)/documents/parental_consents/$(cid)).data.status == 'approved'
            && request.resource.data.parentUid
            == get(/databases/$(database)/documents/parental_consents/$(cid)).data.parentUid
            && request.resource.data.parentUid.size() > 0
          )
          || (
            request.resource.data.parentConsentStatus == 'denied'
            && get(/databases/$(database)/documents/parental_consents/$(cid)).data.status == 'denied'
            && request.resource.data.parentUid == ''
          )
        );
    }

    function minorParentalResubmitAfterDeny(userId) {
      let cid = request.resource.data.parentConsentId;
      return isOwner(userId)
        && emailOtpVerifiedUnchanged()
        && followersCountUnchanged()
        && resource.data.parentConsentStatus == 'denied'
        && request.resource.data.parentConsentStatus == 'pending'
        && cid is string
        && cid.size() > 0
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'parentConsentStatus',
            'parentConsentId',
            'parentInviteEmail',
            'parentInvitePhone',
          ])
        // No [validUserDoc]: merged user docs may carry extra keys; [diff] pins this update.
        && get(/databases/$(database)/documents/parental_consents/$(cid)).data.minorUid == userId
        && get(/databases/$(database)/documents/parental_consents/$(cid)).data.status == 'pending';
    }

    // Clients cannot set or flip emailOtpVerified; only Cloud Functions (Admin SDK) may.
    function emailOtpVerifiedUnchanged() {
      return !('emailOtpVerified' in resource.data)
        ? !('emailOtpVerified' in request.resource.data)
        : request.resource.data.emailOtpVerified == resource.data.emailOtpVerified;
    }

    // Signed-in viewer's following list (users/{uid}.following).
    function authedFollowingList() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.get('following', []);
    }

    function accountTypeIsPrivateGate(t) {
      return t == 'private' || t == 'personal';
    }

    // [authorAccountPrivate] is stored on new reels/stories/streams for clients / future rules.
    //
    // IMPORTANT: Do not use per-document follower checks on [reels] / [stories] / [streams] ROOT
    // collection reads. Broad queries (orderBy + limit) can match docs a user may not read; Firestore
    // then rejects the ENTIRE query ("rules are not filters"). Follower-only hiding for global feeds
    // needs scoped queries (e.g. per-user subcollections), collectionGroup + OR filters, or a
    // server-built feed. Root reads here stay [isSignedIn] so list/get queries work.

    // Path-bound userId (e.g. users/{userId}/storyHighlights): one get(users/{userId}) per query.
    function highlightsPathReadable(userId) {
      return isSignedIn()
        && userId is string
        && userId.size() > 0
        && (
          userId == request.auth.uid
          || !exists(/databases/$(database)/documents/users/$(userId))
          || !accountTypeIsPrivateGate(
            get(/databases/$(database)/documents/users/$(userId)).data.get('accountType', 'private')
          )
          || (authedFollowingList() is list && userId in authedFollowingList())
        );
    }

    // Subcollections under a single story/reel/stream id: storyId/reelId/streamId is path-bound.
    function parentStoryReadable(storyId) {
      let p = get(/databases/$(database)/documents/stories/$(storyId)).data;
      return p.userId == request.auth.uid
        || p.get('authorAccountPrivate', false) != true
        || (
          p.userId is string
          && authedFollowingList() is list
          && p.userId in authedFollowingList()
        );
    }

    function followRequestCreateValid(requestId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['requesterUid', 'targetUid', 'status', 'createdAt'])
        && d.requesterUid == request.auth.uid
        && d.requesterUid is string
        && d.targetUid is string
        && d.targetUid.size() > 0
        && d.requesterUid != d.targetUid
        && d.status == 'pending'
        && d.createdAt != null
        && requestId == request.auth.uid + '_' + d.targetUid;
    }

    function followRequestTargetRespond() {
      let d = resource.data;
      let r = request.resource.data;
      return d.targetUid == request.auth.uid
        && d.status == 'pending'
        && r.requesterUid == d.requesterUid
        && r.targetUid == d.targetUid
        && r.createdAt == d.createdAt
        && r.status in ['accepted', 'declined']
        && r.respondedAt is timestamp
        && r.respondedAt <= request.time + duration.value(24, 'h')
        && r.respondedAt >= request.time - duration.value(24, 'h')
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'respondedAt']);
    }

    // Pending follow requests (private accounts). Doc id: requesterUid_targetUid.
    match /follow_requests/{requestId} {
      allow read: if isSignedIn()
                    && (
                      !exists(/databases/$(database)/documents/follow_requests/$(requestId))
                      || resource.data.requesterUid == request.auth.uid
                      || resource.data.targetUid == request.auth.uid
                    );
      allow create: if isSignedIn() && followRequestCreateValid(requestId);
      allow update: if isSignedIn() && followRequestTargetRespond();
      allow delete: if isSignedIn()
                    && exists(/databases/$(database)/documents/follow_requests/$(requestId))
                    && (
                      resource.data.requesterUid == request.auth.uid
                      || resource.data.targetUid == request.auth.uid
                    );
    }

    // Materialized edge when a private follow request is accepted (Cloud Function only).
    // Doc id: requesterUid_targetUid (same as follow_requests id). Requester may delete on unfollow.
    match /follow_edges/{edgeId} {
      allow read: if isSignedIn()
                    && (
                      !exists(/databases/$(database)/documents/follow_edges/$(edgeId))
                      || resource.data.requesterUid == request.auth.uid
                      || resource.data.targetUid == request.auth.uid
                    );
      allow create, update: if false;
      allow delete: if isSignedIn()
                    && resource.data.requesterUid == request.auth.uid;
    }

    // ── Token requests (Firestore-based Agora token generation) ───────────────
    // Users write their own requests; Cloud Function (Admin SDK) writes back.
    match /token_requests/{requestId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isSignedIn()
                          && resource.data.userId == request.auth.uid;
      allow update: if false; // only Cloud Function (Admin SDK) may update
    }

    // Parent / guardian approval for minors under 16.
    match /parental_consents/{consentId} {
      allow read: if isSignedIn() && parentalConsentReadAllowed();
      allow create: if isSignedIn() && parentalConsentCreateValid();
      allow update: if isSignedIn()
                    && resource.data.status == 'pending'
                    && request.resource.data.minorUid == resource.data.minorUid
                    && request.resource.data.minorUsername == resource.data.minorUsername
                    && request.resource.data.parentEmailLower == resource.data.parentEmailLower
                    && request.resource.data.parentPhoneNormalized == resource.data.parentPhoneNormalized
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['status', 'respondedAt', 'parentUid'])
                    && request.resource.data.respondedAt is timestamp
                    && request.resource.data.respondedAt
                      <= request.time + duration.value(24, 'h')
                    && request.resource.data.respondedAt
                      >= request.time - duration.value(24, 'h')
                    && parentalConsentParentCanRespond()
                    && (
                      (
                        request.resource.data.status == 'approved'
                        && request.resource.data.parentUid == request.auth.uid
                      )
                      || (
                        request.resource.data.status == 'denied'
                        && request.resource.data.parentUid == ''
                      )
                    );
      // Minor can remove an orphan or mistaken [pending] consent they created (no parent yet).
      allow delete: if isSignedIn()
                    && resource.data.minorUid == request.auth.uid
                    && resource.data.status == 'pending';
    }

    // ── User profile doc only: users/{uid} (one segment after users/) ─────────
    // following / blockedUsers live here; only the owner may write the doc.
    // Exception: any signed-in user may remove *only themselves* from another
    // user's following array (powers the "remove follower" feature).
    match /users/{userId} {
      // Needed for pre-auth login lookup by username/displayName.
      allow read: if true;
      allow create: if isOwner(userId)
                    && validUserDoc(userId)
                    && request.resource.data.followersCount == 0;
      allow update: if (
                      (
                        isOwner(userId)
                        && validUserDoc(userId)
                        && followersCountUnchanged()
                        && emailOtpVerifiedUnchanged()
                        && parentalContactFieldsUnchanged()
                      )
                      || minorDobAndParentGateUpdate(userId)
                      || minorParentInviteSubmit(userId)
                      || minorParentalConsentSync(userId)
                      || minorParentalResubmitAfterDeny(userId)
                    )
                    || (isSignedIn()
                        && !isOwner(userId)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['following'])
                        && request.auth.uid in resource.data.following
                        && !(request.auth.uid in request.resource.data.following)
                        && request.resource.data.following.size() == resource.data.following.size() - 1);
      allow delete: if isOwner(userId);
    }

    // FCM device tokens (one doc per device; Cloud Functions read to send pushes).
    match /users/{userId}/push_tokens/{docId} {
      allow read, write, delete: if isOwner(userId);
    }

    // Notification category preferences (owner only; Functions read via Admin SDK).
    match /users/{userId}/settings/{settingId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
                            && settingId == 'notifications'
                            && validNotificationSettingsWrite();
      allow delete: if isOwner(userId) && settingId == 'notifications';
    }

    // Per-user chat summaries (Cloud Functions manage most writes).
    match /users/{userId}/chatSummaries/{chatId} {
      allow read: if isOwner(userId);
      allow update: if isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['unreadCount', 'muted', 'archived', 'pinned', 'clearedAt', 'requestStatus']);
      allow create: if false;
      allow delete: if false;
    }

    // Per-user presence (safe subcollection).
    match /users/{userId}/presence/{docId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId)
                   && request.resource.data.keys().hasOnly(['isOnline', 'lastActiveAt'])
                   && request.resource.data.isOnline is bool
                   && request.resource.data.lastActiveAt is timestamp;
      allow delete: if isOwner(userId);
    }

    // ── App collections (explicit so list/get never rely on a fragile catch‑all) ──
    // ── Stories (24h content): owner creates/deletes; anyone signed-in can read;
    // non-owners may only patch viewedBy. likes/comments are updated by Cloud Functions only.
    function storyCreateKeys() {
      return request.resource.data.keys().hasOnly([
        'userId',
        'username',
        'avatarUrl',
        'mediaUrl',
        'caption',
        'createdAt',
        'expiresAt',
        'viewedBy',
        'mediaType',
        'durationMs',
        'likes',
        'comments',
        'segmentGroupId',
        'authorAccountPrivate',
      ]);
    }

    function storyValidCreate() {
      return storyCreateKeys()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.avatarUrl is string
        && request.resource.data.mediaUrl is string
        && request.resource.data.caption is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.viewedBy is list
        && request.resource.data.mediaType is string
        && request.resource.data.mediaType in ['image', 'video']
        && request.resource.data.durationMs is int
        && request.resource.data.likes is int
        && request.resource.data.likes == 0
        && request.resource.data.comments is int
        && request.resource.data.comments == 0
        && request.resource.data.segmentGroupId is string
        && request.resource.data.authorAccountPrivate is bool
        && request.resource.data.authorAccountPrivate
          == accountTypeIsPrivateGate(
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get(
              'accountType',
              'private'
            )
          );
    }

    function storyOwnerIdUnchanged() {
      return request.resource.data.userId == resource.data.userId;
    }

    function storyViewedByOnlyUpdate() {
      return storyOwnerIdUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedBy']);
    }

    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && storyValidCreate();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
                    && storyOwnerIdUnchanged()
                    && (
                      resource.data.userId == request.auth.uid
                      || storyViewedByOnlyUpdate()
                    );
    }

    match /stories/{storyId}/comments/{commentId} {
      allow read: if isSignedIn() && parentStoryReadable(storyId);
      allow create: if isSignedIn()
                    && parentStoryReadable(storyId)
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasOnly([
                      'userId',
                      'username',
                      'avatarUrl',
                      'text',
                      'parentId',
                      'likeCount',
                      'createdAt',
                      'isVerified',
                    ])
                    && request.resource.data.username is string
                    && request.resource.data.avatarUrl is string
                    && request.resource.data.text is string
                    && request.resource.data.parentId is string
                    && request.resource.data.likeCount is int
                    && request.resource.data.likeCount == 0
                    && request.resource.data.createdAt is timestamp
                    && request.resource.data.isVerified is bool;
      // Subtree deletes may include reply docs by other users (same as reels pattern).
      allow delete: if isSignedIn() && parentStoryReadable(storyId);
      allow update: if isSignedIn()
                    && parentStoryReadable(storyId)
                    && request.resource.data.userId == resource.data.userId
                    && (
                      resource.data.userId == request.auth.uid
                      || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['likeCount'])
                    );
    }

    match /stories/{storyId}/comments/{commentId}/likes/{likerId} {
      allow read: if isSignedIn() && parentStoryReadable(storyId);
      allow create: if isSignedIn()
                    && parentStoryReadable(storyId)
                    && likerId == request.auth.uid
                    && request.resource.data.keys().hasOnly(['userId', 'likedAt'])
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.likedAt is timestamp;
      allow delete: if isSignedIn()
                    && likerId == request.auth.uid
                    && parentStoryReadable(storyId);
      allow update: if false;
    }

    // Top-level likes index: storyId varies per doc — do not use per-row get(story) for reads
    // (breaks queries). Create/delete still gated on the target story.
    match /storyLikes/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && exists(/databases/$(database)/documents/stories/$(request.resource.data.storyId))
                    && parentStoryReadable(request.resource.data.storyId)
                    && request.resource.data.keys().hasOnly(['userId', 'storyId', 'likedAt'])
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.storyId is string
                    && request.resource.data.storyId.size() > 0
                    && request.resource.data.likedAt is timestamp
                    && id == request.auth.uid + '_' + request.resource.data.storyId;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /users/{userId}/storyHighlights/{highlightId} {
      allow read: if isSignedIn() && highlightsPathReadable(userId);
      allow create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/storyHighlights/{highlightId}/items/{itemId} {
      allow read: if isSignedIn() && highlightsPathReadable(userId);
      allow create, update, delete: if isOwner(userId);
    }

    // Public favorites (profile star tab). Same visibility as story highlights.
    match /users/{userId}/favoriteReels/{reelId} {
      allow read: if isSignedIn() && highlightsPathReadable(userId);
      // Do not require favoritedAt to be a literal timestamp: client may send
      // serverTimestamp sentinel which rules do not always classify as timestamp.
      allow create: if isOwner(userId)
                    && request.resource.data.keys().hasOnly(['reelId', 'favoritedAt'])
                    && request.resource.data.reelId == reelId
                    && request.resource.data.reelId is string
                    && request.resource.data.reelId.size() > 0;
      allow delete: if isOwner(userId);
      allow update: if false;
    }

    // Private bookmarks — only the account owner may list or modify.
    match /users/{userId}/privateSavedReels/{reelId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
                    && request.resource.data.keys().hasOnly(['reelId', 'savedAt'])
                    && request.resource.data.reelId == reelId
                    && request.resource.data.reelId is string
                    && request.resource.data.reelId.size() > 0;
      allow delete: if isOwner(userId);
      allow update: if false;
    }

    match /reels/{reelId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /reels/{reelId}/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /streams/{streamId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /streams/{streamId}/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /userLikes/{id} {
      allow read, write: if isSignedIn();
    }

    // Legacy collection — kept for one client-side migration into privateSavedReels.
    match /userSaves/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasOnly(['userId', 'reelId', 'savedAt'])
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.reelId is string
                    && request.resource.data.reelId.size() > 0
                    && id == request.auth.uid + '_' + request.resource.data.reelId;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /comment_reports/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    match /notifications/{id} {
      allow create: if isSignedIn()
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.recipientId is string
                    && request.resource.data.recipientId.size() > 0
                    && request.resource.data.type is string
                    && request.resource.data.message is string;
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow delete: if false;
    }

    match /cloudflare_upload_requests/{id} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isSignedIn()
                          && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // AI hashtag suggestions (Firestore-triggered Cloud Function; keys stay on server).
    match /hashtag_generation_requests/{requestId} {
      // minCount: accept int or float from clients (SDKs may encode 30 as double).
      // createdAt: do not require it on create (avoid serverTimestamp sentinel edge cases).
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 200
                    && request.resource.data.status == 'pending'
                    && (!('description' in request.resource.data)
                        || (request.resource.data.description is string
                            && request.resource.data.description.size() <= 500))
                    && (!('category' in request.resource.data)
                        || (request.resource.data.category is string
                            && request.resource.data.category.size() <= 50))
                    && (!('minCount' in request.resource.data)
                        || (
                          (request.resource.data.minCount is int
                            || request.resource.data.minCount is float)
                          && request.resource.data.minCount >= 30
                          && request.resource.data.minCount <= 40
                        ));
      allow read, delete: if isSignedIn()
                          && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // User verification requests (manual CRM/admin review workflow).
    match /verification_requests/{requestId} {
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow read, delete: if isSignedIn()
                          && resource.data.uid == request.auth.uid;
      allow update: if false; // only admin/CRM should update status
    }

    // Email OTP (Firestore-triggered Cloud Functions; same pattern as token_requests).
    match /email_otp_send_requests/{requestId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isSignedIn()
                          && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /email_otp_verify_requests/{requestId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.code is string
                    && request.resource.data.code.matches('^[0-9]{4}$');
      allow read, delete: if isSignedIn()
                          && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /whatsapp_otp_send_requests/{requestId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.phoneNumber is string;
      allow read, delete: if isSignedIn()
                          && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /whatsapp_otp_verify_requests/{requestId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.phoneNumber is string
                    && request.resource.data.code is string
                    && request.resource.data.code.matches('^[0-9]{4}$');
      allow read, delete: if isSignedIn()
                          && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // Creator subscription server-owned records.
    // Clients can read only when they are the subscriber or creator.
    // All writes happen via Cloud Functions (Admin SDK).
    match /creatorSubscriptions/{docId} {
      // Single-doc .get() on a missing doc still evaluates rules; without the
      // exists() branch, empty resource.data fails subscriber/creator checks and
      // clients see permission-denied instead of "not found".
      allow read: if isSignedIn()
                  && (
                    !exists(/databases/$(database)/documents/creatorSubscriptions/$(docId))
                    || resource.data.subscriberId == request.auth.uid
                    || resource.data.creatorId == request.auth.uid
                  );
      allow create, update, delete: if false;
    }

    // Mutation requests for creator subscriptions (client -> function).
    // Clients can create/delete/read only their own requests; no client updates.
    match /creator_subscription_requests/{requestId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.creatorId is string
                    && request.resource.data.creatorId.size() > 0
                    && request.resource.data.action is string
                    && request.resource.data.action in ['subscribe', 'cancel', 'resume']
                    && request.resource.data.status == 'pending';
      allow read, delete: if isSignedIn()
                          && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ── Chat documents ────────────────────────────────────────────────────────
    function isChatParticipant(chatId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
    }

    match /chats/{chatId} {
      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.participantIds;

      allow create: if isSignedIn()
                    && request.resource.data.participantIds is list
                    && request.auth.uid in request.resource.data.participantIds
                    && request.resource.data.createdBy == request.auth.uid
                    && (
                      (
                        request.resource.data.type == 'direct'
                        && request.resource.data.participantIds.size() == 2
                      )
                      ||
                      (
                        request.resource.data.type == 'group'
                        && request.resource.data.participantIds.size() >= 3
                        && request.resource.data.participantIds.size() <= 256
                        && request.resource.data.admins is list
                        && request.auth.uid in request.resource.data.admins
                        && request.resource.data.groupName is string
                        && request.resource.data.groupName.size() > 0
                      )
                    );

      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participantIds
                    && (
                      // Any participant can update their own muted/cleared/deleted fields
                      (
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['mutedBy', 'clearedAtBy', 'deletedFor', 'updatedAt'])
                      )
                      ||
                      // Self-leave: any participant can remove themselves
                      (
                        resource.data.type == 'group'
                        && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['participantIds', 'participantMap', 'admins', 'updatedAt'])
                        && !(request.auth.uid in request.resource.data.participantIds)
                        && request.resource.data.participantIds.size() == resource.data.participantIds.size() - 1
                        && request.resource.data.participantIds.hasAll(
                             resource.data.participantIds.removeAll([request.auth.uid])
                           )
                        // Block if this would leave zero admins with remaining participants
                        && (
                          request.resource.data.admins.size() > 0
                          || request.resource.data.participantIds.size() == 0
                        )
                      )
                      ||
                      // Admins can update group metadata
                      (
                        resource.data.type == 'group'
                        && request.auth.uid in resource.data.admins
                        && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['groupName', 'groupImageUrl', 'participantIds', 'participantMap', 'admins', 'updatedAt'])
                        // Admins cannot empty the admins list while participants remain
                        && (
                          request.resource.data.admins.size() > 0
                          || request.resource.data.participantIds.size() <= 1
                        )
                      )
                    );

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);

        allow create: if isChatParticipant(chatId)
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.deletedForEveryone == false
                      && (
                        // Normal (non-view-once) messages
                        (
                          request.resource.data.isViewOnce == false
                          && (
                            (
                              request.resource.data.type == 'text'
                              && request.resource.data.text is string
                              && request.resource.data.text.size() > 0
                              && request.resource.data.text.size() <= 5000
                            )
                            ||
                            (
                              request.resource.data.type in ['image', 'video']
                              && request.resource.data.mediaUrl is string
                              && request.resource.data.mediaUrl.size() > 0
                              && request.resource.data.storagePath is string
                              && request.resource.data.storagePath.size() > 0
                            )
                            ||
                            (
                              request.resource.data.type == 'audio'
                              && request.resource.data.mediaUrl is string
                              && request.resource.data.mediaUrl.size() > 0
                              && request.resource.data.storagePath is string
                              && request.resource.data.storagePath.size() > 0
                            )
                            ||
                            (
                              request.resource.data.type == 'gif'
                              && request.resource.data.mediaUrl is string
                              && request.resource.data.mediaUrl.size() > 0
                            )
                          )
                        )
                        ||
                        // View-once media messages
                        (
                          request.resource.data.isViewOnce == true
                          && request.resource.data.type in ['image', 'video']
                          && request.resource.data.mediaUrl is string
                          && request.resource.data.mediaUrl.size() > 0
                          && request.resource.data.storagePath is string
                          && request.resource.data.storagePath.size() > 0
                          && request.resource.data.viewedBy is list
                          && request.resource.data.viewedBy.size() == 0
                          && request.resource.data.deletedFor is list
                          && request.resource.data.deletedFor.size() == 0
                        )
                        ||
                        // Call system messages
                        (
                          request.resource.data.isViewOnce == false
                          && request.resource.data.type == 'call'
                          && request.resource.data.text is string
                          && request.resource.data.text.size() > 0
                          && request.resource.data.metadata is map
                        )
                      );

        allow update: if isChatParticipant(chatId)
                      && (
                        // Delete for self: add own uid to deletedFor
                        (
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor'])
                          && request.resource.data.deletedFor.hasAll(resource.data.deletedFor)
                          && request.resource.data.deletedFor.size() == resource.data.deletedFor.size() + 1
                          && request.auth.uid in request.resource.data.deletedFor
                          && !(request.auth.uid in resource.data.deletedFor)
                        )
                        ||
                        // Delete for everyone: sender only, within 15 min
                        (
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedForEveryone'])
                          && resource.data.senderId == request.auth.uid
                          && request.resource.data.deletedForEveryone == true
                          && resource.data.deletedForEveryone == false
                          && resource.data.createdAt is timestamp
                          && request.time - resource.data.createdAt < duration.value(15, 'm')
                        )
                        ||
                        // Mark seen: participant can only add their own uid to seenBy
                        (
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenBy'])
                          && request.resource.data.seenBy.hasAll(resource.data.seenBy)
                          && request.resource.data.seenBy.size() == resource.data.seenBy.size() + 1
                          && request.auth.uid in request.resource.data.seenBy
                          && !(request.auth.uid in resource.data.seenBy)
                        )
                        ||
                        // Mark view-once viewed: non-sender participant adds only their own uid to viewedBy
                        (
                          resource.data.isViewOnce == true
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedBy'])
                          && request.auth.uid != resource.data.senderId
                          && request.resource.data.viewedBy.hasAll(resource.data.viewedBy)
                          && request.resource.data.viewedBy.size() == resource.data.viewedBy.size() + 1
                          && request.auth.uid in request.resource.data.viewedBy
                          && !(request.auth.uid in resource.data.viewedBy)
                        )
                      );

        allow delete: if false;
      }

      // ── Typing indicators ──────────────────────────────────────────────────
      match /typing/{uid} {
        allow read: if isChatParticipant(chatId);
        allow create, update: if isSignedIn()
                              && request.auth.uid == uid
                              && isChatParticipant(chatId)
                              && request.resource.data.keys().hasOnly(['uid', 'displayName', 'updatedAt'])
                              && request.resource.data.uid == uid
                              && request.resource.data.displayName is string
                              && request.resource.data.updatedAt is timestamp;
        allow delete: if isSignedIn()
                      && request.auth.uid == uid
                      && isChatParticipant(chatId);
      }
    }

    // ── Call Sessions ───────────────────────────────────────────────────────────
    match /callSessions/{callId} {
      function isCallParticipant() {
        return isSignedIn()
               && request.auth.uid in resource.data.participantIds;
      }

      allow read: if isSignedIn()
                  && request.auth.uid in resource.data.participantIds;

      allow create: if isSignedIn()
                    && request.resource.data.callerId == request.auth.uid
                    && request.resource.data.participantIds is list
                    && request.auth.uid in request.resource.data.participantIds
                    && request.resource.data.calleeIds is list
                    && !(request.auth.uid in request.resource.data.calleeIds)
                    && request.resource.data.type in ['audio', 'video']
                    && request.resource.data.status == 'ringing'
                    && request.resource.data.chatId is string
                    && request.resource.data.agoraChannelName is string;

      allow update: if isCallParticipant()
                    && request.resource.data.callerId == resource.data.callerId
                    && request.resource.data.chatId == resource.data.chatId
                    && request.resource.data.participantIds == resource.data.participantIds
                    && request.resource.data.calleeIds == resource.data.calleeIds
                    && request.resource.data.type == resource.data.type
                    && request.resource.data.agoraChannelName == resource.data.agoraChannelName
                    && (
                      (resource.data.status == 'ringing' && request.resource.data.status in ['active', 'declined', 'missed'])
                      || (resource.data.status == 'active' && request.resource.data.status == 'ended')
                      || (
                        request.resource.data.status == resource.data.status
                        && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['agoraUidMap', 'updatedAt'])
                      )
                    );

      allow delete: if false;
    }

    // Deny everything not explicitly allowed above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}