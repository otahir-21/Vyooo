rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Token requests (Firestore-based Agora token generation) ───────────────
    // Users write their own requests; Cloud Function (Admin SDK) writes back.
    match /token_requests/{requestId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read, delete: if request.auth != null
                          && resource.data.userId == request.auth.uid;
      allow update: if false; // only Cloud Function (Admin SDK) may update
    }

    // ── Everything else — allow authenticated users ───────────────────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
