rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Token requests (Firestore-based Agora token generation) ───────────────
    // Users write their own requests; Cloud Function (Admin SDK) writes back.
    match /token_requests/{requestId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read, delete: if request.auth != null
                          && resource.data.userId == request.auth.uid;
      allow update: if false; // only Cloud Function (Admin SDK) may update
    }

    // ── User profile doc only: users/{uid} (one segment after users/) ─────────
    // following / blockedUsers live here; only the owner may write the doc.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── App collections (explicit so list/get never rely on a fragile catch‑all) ──
    match /stories/{storyId} {
      allow read, write: if request.auth != null;
    }

    match /reels/{reelId} {
      allow read, write: if request.auth != null;
    }
    match /reels/{reelId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /streams/{streamId} {
      allow read, write: if request.auth != null;
    }
    match /streams/{streamId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // userLikes, userSaves, comment_reports, cloudflare_upload_requests, etc.
    // IMPORTANT: exclude only the *top-level* profile path users/{uid}, not users/** .
    // Using users/.* wrongly removed access to all paths under users/... and broke OR matching.
    match /{document=**} {
      allow read, write: if request.auth != null
          && !document.matches('users/[^/]+$');
    }
  }
}
