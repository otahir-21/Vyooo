# Firebase requires iOS 12+. Uncomment to set explicitly.
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # Static linkage avoids dynamic-framework + FFI edge cases (Agora Iris / DartWorker crashes on device).
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Some plugins (e.g. purchases_flutter/PurchasesHybridCommon) require
      # a higher minimum deployment target than older lockfile snapshots.
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_CAMERA=1',
        'PERMISSION_MICROPHONE=1',
        'PERMISSION_PHOTOS=1',
      ]
    end
  end

  # ── Debug-device Iris/Agora crash fix ───────────────────────────────────────
  # Root cause: Agora xcframeworks are DYNAMIC libraries embedded in the app
  # bundle and loaded by dyld at startup. Their C++ static initializers run
  # (we see "iris version: 4.6.2-build.1" in the log) before any Dart code,
  # and corrupt state that Flutter JIT DartWorker later trips on →
  # EXC_BAD_ACCESS (code=50 / KERN_NOT_IN_MAP) in thread DartWorker.
  #
  # Fix: remove the `if [[ "$CONFIGURATION" == "Debug" ]]` embed block from
  # the generated Pods-Runner-frameworks.sh so Agora dynamic frameworks are
  # never copied into the Debug .app bundle. All Agora frameworks are already
  # -weak_framework linked, so dyld silently skips absent frameworks at launch.
  # The strip_agora_at_launch.sh build phase already removes plugin registration,
  # completing the two-part defence.
  #
  # Profile / Release blocks in frameworks.sh are left intact; Agora works
  # normally in those configurations.
  #
  # Idempotent: re-runs every `pod install` to survive CocoaPods regeneration.

  support = installer.sandbox.root.join('Target Support Files', 'Pods-Runner')

  # 1. Patch Pods-Runner-frameworks.sh: delete the Debug configuration block.
  sh_file = support.join('Pods-Runner-frameworks.sh')
  if sh_file.exist?
    content = sh_file.read
    # Match: if [[ "$CONFIGURATION" == "Debug" ]]; then ... fi\n
    # Uses [\s\S]*? (lazy, matches newlines) so we stop at the FIRST `fi`.
    patched = content.gsub(
      /if \[\[ "\$CONFIGURATION" == "Debug" \]\]; then\n[\s\S]*?fi\n/,
      ""
    )
    sh_file.write(patched) if patched != content
  end

  # 2. Clear Agora entries from the Debug embed xcfilelists so Xcode's
  #    incremental-build dependency tracking stays consistent.
  %w[input output].each do |direction|
    list_path = support.join("Pods-Runner-frameworks-Debug-#{direction}-files.xcfilelist").to_s
    next unless File.exist?(list_path)
    lines = File.readlines(list_path, chomp: true)
    filtered = lines.reject { |l| l =~ /AgoraIrisRTC|AgoraVideo_Special|\/Agora|\/aosl\.framework|\/video_dec\.framework|\/video_enc\.framework/ }
    File.open(list_path, 'w') { |f| filtered.each { |l| f.puts l } }
  end
end
